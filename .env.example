# Public site URL used for metadata, sitemap, and social previews.
# Do not put secrets in this file.
NEXT_PUBLIC_SITE_URL=https://tededmunds.com

# Optional local GUDID Express API. The FDA dashboard tries this first, then
# falls back to /gudid-dashboard.json for Vercel/static deployments.
NEXT_PUBLIC_GUDID_API_URL=http://127.0.0.1:8787
